{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./*"],
      // "@repo/ui/*": ["../../packages/ui/src/*"],
      // "@repo/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
    "../../packages/ui/src/**/*.tsx",
    "../../packages/types/src/**/*.ts"
  ],
  "exclude": ["node_modules"]
}